main min-h-screen grid place-items-center bg-white
  div w-min[520px] max-w-[calc(100vw-32px)] grid gap-4 justify-items-center
    div w-11 h-11 grid place-items-center border border-black bg-black text-white font-bold text-xs leading-none
      "rs"
    h1 m-0 text-lg font-bold tracking-normal text-black
      "rs_vimium"
    form w-full grid gap-3
      input #search-input w-full box-border px-3 py-2.5 border border-black bg-white text-black text-sm font-mono outline-none focus:shadow-[0_0_0_2px_#000] placeholder:text-[#666]
      ul #suggest-list m-0 p-0 list-none grid gap-0